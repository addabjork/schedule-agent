# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Calendar
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
# For cloud deployments (Railway/Render), paste the full contents of token.json here:
# GOOGLE_TOKEN_JSON={"token": "...", "refresh_token": "...", ...}

# Twilio (SMS/MMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
REPLY_EMAIL_FROM=schedule@yourdomain.com

# Your family
USER_EMAIL=you@example.com
HUSBAND_EMAIL=husband@example.com

# Timezone (IANA format — e.g. America/New_York, America/Chicago, America/Los_Angeles)
TIMEZONE=America/New_York
